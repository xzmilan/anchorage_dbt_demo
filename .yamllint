---
extends: default

rules:
  # Relax line length to match SQLFluff's LT05 limit
  line-length:
    max: 120
    level: warning

  # Allow truthy values like 'true'/'false' (used in dbt schema YAML)
  truthy:
    allowed-values: ["true", "false", "on", "off", "yes", "no"]
    level: warning

  # Allow duplicate keys in anchors (dbt uses merge keys)
  key-duplicates: disable

  # dbt YAML files commonly use 2-space indentation
  indentation:
    spaces: 2
    indent-sequences: consistent
